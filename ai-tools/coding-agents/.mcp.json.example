{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "disabled": true
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "disabled": true
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp",
      "disabled": true
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp",
      "disabled": true
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "disabled": true
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp",
      "disabled": true
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "db": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub", "--dsn", "postgresql://user:password@host:5432/database"],
      "disabled": true
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "google-drive": {
      "type": "http",
      "url": "https://drive.google.com/mcp",
      "disabled": true
    },
    "postgres": {
      "type": "http",
      "url": "https://postgres.mcp.server/mcp",
      "disabled": true
    }
  }
}
