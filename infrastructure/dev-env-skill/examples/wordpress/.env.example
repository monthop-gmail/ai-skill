# WordPress
# ใส่ config เพิ่มเติมสำหรับ Redis Object Cache + reverse proxy
WP_EXTRA_CONFIG=define('WP_REDIS_HOST', 'redis'); define('WP_REDIS_PORT', 6379); define('FORCE_SSL_ADMIN', true); define('WP_HOME', 'https://blog.dev.example.com'); define('WP_SITEURL', 'https://blog.dev.example.com');

# Database
DB_NAME=wordpress
DB_USER=wordpress
DB_PASS=wordpress
DB_ROOT_PASS=rootpass

# Cloudflare Tunnel
# สร้าง Tunnel บน CF Dashboard → Zero Trust → Networks → Tunnels
# ตั้ง Public Hostname: blog.dev.example.com → http://wordpress:80
CF_TUNNEL_TOKEN=
