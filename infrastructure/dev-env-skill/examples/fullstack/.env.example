# App
ENV=development
VITE_API_URL=https://api.dev.example.com

# Auth
JWT_SECRET=change-me-in-production

# Database
DB_NAME=app
DB_USER=app
DB_PASS=secret

# Cloudflare Tunnel
# สร้าง 2 Tunnels บน CF Dashboard:
#   1) web.dev.example.com → http://frontend:80
#   2) api.dev.example.com → http://api:4000
CF_TUNNEL_TOKEN_WEB=
CF_TUNNEL_TOKEN_API=
