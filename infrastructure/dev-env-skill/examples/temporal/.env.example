# Temporal
TASK_QUEUE=main-queue
UI_HOST=temporal.dev.example.com

# Database
DB_USER=temporal
DB_PASS=temporal

# Cloudflare Tunnels
# สร้าง 2 Tunnels บน CF Dashboard:
#   1) temporal.dev.example.com     → http://temporal-ui:8080
#   2) temporal-api.dev.example.com → TCP temporal:7233 (gRPC)
CF_TUNNEL_TOKEN_UI=
CF_TUNNEL_TOKEN_API=
