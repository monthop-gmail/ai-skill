# Nextcloud
ADMIN_USER=admin
ADMIN_PASS=changeme
TRUSTED_DOMAIN=cloud.dev.example.com

# External storage mount (path บน host)
EXTERNAL_STORAGE=./external

# Database
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASS=nextcloud

# Cloudflare Tunnel
# สร้าง Tunnel บน CF Dashboard → Zero Trust → Networks → Tunnels
# ตั้ง Public Hostname: cloud.dev.example.com → http://nextcloud:80
#
# สำคัญ: ตั้ง HTTP Settings บน tunnel:
#   - HTTP/2 Origin: enabled
#   - No TLS Verify: enabled (เพราะ origin เป็น http)
CF_TUNNEL_TOKEN=
