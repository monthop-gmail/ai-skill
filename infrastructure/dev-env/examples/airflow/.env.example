# Airflow
ADMIN_USER=admin
ADMIN_PASS=admin
LOAD_EXAMPLES=false
WEBSERVER_SECRET=change-me-use-random-string

# Fernet Key (สำหรับ encrypt connections/variables)
# สร้าง: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Database
DB_NAME=airflow
DB_USER=airflow
DB_PASS=airflow

# Cloudflare Tunnel
# สร้าง Tunnel บน CF Dashboard → Zero Trust → Networks → Tunnels
# ตั้ง Public Hostname: airflow.dev.example.com → http://airflow-webserver:8080
CF_TUNNEL_TOKEN=
