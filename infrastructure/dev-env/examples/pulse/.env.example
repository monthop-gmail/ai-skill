# ─── Timezone ──────────────────────────────────────────
TZ=Asia/Bangkok

# ─── Odoo ERP ─────────────────────────────────────────
ODOO_VERSION=18
ODOO_DB_USER=odoo
ODOO_DB_PASS=odoo

# ─── WordPress ────────────────────────────────────────
WP_DB_NAME=wordpress
WP_DB_USER=wordpress
WP_DB_PASS=wordpress
WP_DB_ROOT_PASS=rootpass
WP_EXTRA_CONFIG=define('WP_REDIS_HOST', 'redis'); define('WP_REDIS_PORT', 6379); define('FORCE_SSL_ADMIN', true); define('WP_HOME', 'https://www.dev.example.com'); define('WP_SITEURL', 'https://www.dev.example.com');

# ─── n8n Workflow ─────────────────────────────────────
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASS=n8n
N8N_HOST=n8n.dev.example.com
N8N_WEBHOOK_URL=https://n8n.dev.example.com/
N8N_ENCRYPTION_KEY=change-me-use-random-string

# ─── Cloudflare Tunnels ──────────────────────────────
# สร้าง 5 Tunnels บน CF Dashboard:
#
#   1) erp.dev.example.com      → http://odoo:8069
#   2) www.dev.example.com      → http://wordpress:80
#   3) nodered.dev.example.com  → http://nodered:1880
#   4) mqtt.dev.example.com     → tcp://emqx:1883  (Type: TCP)
#   5) n8n.dev.example.com      → http://n8n:5678
#
CF_TUNNEL_TOKEN_ODOO=
CF_TUNNEL_TOKEN_WP=
CF_TUNNEL_TOKEN_NODERED=
CF_TUNNEL_TOKEN_MQTT=
CF_TUNNEL_TOKEN_N8N=
