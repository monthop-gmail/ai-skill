# ─── Timezone ──────────────────────────────────────────
TZ=Asia/Bangkok

# ─── Database ─────────────────────────────────────────
DB_USER=odoo
DB_PASS=odoo

# ─── Odoo ERP ─────────────────────────────────────────
ODOO_VERSION=18

# ─── Cloudflare Tunnels ──────────────────────────────
# สร้าง 2 Tunnels บน CF Dashboard:
#
#   1) erp.dev.example.com          → http://odoo:8069
#   2) dbadmin.dev.example.com      → http://adminer:8080
#
CF_TUNNEL_TOKEN_ODOO=
CF_TUNNEL_TOKEN_ADMINER=
