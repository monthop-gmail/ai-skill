# LLM Provider: "ollama" (local, free) หรือ "openai" (cloud, paid)
LLM_PROVIDER=ollama

# Ollama Models
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text

# OpenAI (ถ้าใช้ LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Cloudflare Tunnels
# สร้าง 2 Tunnels บน CF Dashboard:
#   1) rag.dev.example.com    → http://api:3000
#   2) qdrant.dev.example.com → http://qdrant:6333  (Qdrant Dashboard)
CF_TUNNEL_TOKEN_API=
CF_TUNNEL_TOKEN_QDRANT=
