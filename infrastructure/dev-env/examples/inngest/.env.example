# Inngest
# Dev: ใช้ค่า default ได้เลย (inngest dev server)
# PRD: สมัคร https://inngest.com → ได้ keys
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# Cloudflare Tunnels
# สร้าง 2 Tunnels บน CF Dashboard:
#   1) app.dev.example.com      → http://app:3000
#   2) inngest.dev.example.com  → http://inngest-server:8288  (Dev UI)
CF_TUNNEL_TOKEN_APP=
CF_TUNNEL_TOKEN_INNGEST=
