# ─── Timezone ──────────────────────────────────────────
TZ=Asia/Bangkok

# ─── Odoo ─────────────────────────────────────────────
# ODOO_MAJOR_VERSION selects Dockerfile: 18 → Dockerfile.18, 19 → Dockerfile.19
ODOO_MAJOR_VERSION=19
ODOO_VERSION=19.0

# ─── Database ─────────────────────────────────────────
DB_USER=odoo
DB_PASS=odoo

# ─── Cloudflare Tunnels ──────────────────────────────
# สร้าง 2 Tunnels บน CF Dashboard:
#
#   1) acc.dev.example.com          → http://odoo:8069
#   2) dbadmin.dev.example.com      → http://adminer:8080
#
CF_TUNNEL_TOKEN_ODOO=
CF_TUNNEL_TOKEN_ADMINER=
