# Odoo
# ODOO_MAJOR_VERSION selects Dockerfile: 18 → Dockerfile.18, 19 → Dockerfile.19
ODOO_MAJOR_VERSION=19
ODOO_VERSION=19.0

# Database
DB_USER=odoo
DB_PASS=odoo

# Cloudflare Tunnel
# สร้าง Tunnel บน CF Dashboard → Zero Trust → Networks → Tunnels
# ตั้ง Public Hostname: acc.dev.example.com → http://odoo:8069
CF_TUNNEL_TOKEN=
