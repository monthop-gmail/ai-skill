# Keycloak
KC_HOSTNAME=auth.dev.example.com
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin

# Database
DB_NAME=keycloak
DB_USER=keycloak
DB_PASS=keycloak

# Cloudflare Tunnel
# สร้าง Tunnel บน CF Dashboard → Zero Trust → Networks → Tunnels
# ตั้ง Public Hostname: auth.dev.example.com → http://keycloak:8080
CF_TUNNEL_TOKEN=
