# ─── Timezone ──────────────────────────────────────────
TZ=Asia/Bangkok

# ─── Shared PostgreSQL ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Odoo ERP ─────────────────────────────────────────
ODOO_VERSION=17
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=odoo

# ─── Keycloak SSO ─────────────────────────────────────
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── ThingsBoard IoT ─────────────────────────────────
TB_DB_USER=thingsboard
TB_DB_PASSWORD=thingsboard

# ─── MinIO Object Storage ────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Samba NAS ────────────────────────────────────────
SAMBA_USER=nasuser
SAMBA_PASSWORD=naspass

# ─── Cloudflare Tunnels ──────────────────────────────
# สร้าง 6 Tunnels บน CF Dashboard:
#
#   1) auth.dev.example.com         → http://keycloak:8080
#   2) erp.dev.example.com          → http://odoo:8069
#   3) iot.dev.example.com          → http://thingsboard:9090
#   4) mqtt.dev.example.com         → tcp://thingsboard:1883  (Type: TCP)
#   5) s3.dev.example.com           → http://minio:9000
#   6) s3-console.dev.example.com   → http://minio:9001
#
# NAS (Samba) = LAN only, ไม่ต้องสร้าง tunnel
#
CF_TUNNEL_TOKEN_KEYCLOAK=
CF_TUNNEL_TOKEN_ODOO=
CF_TUNNEL_TOKEN_TB=
CF_TUNNEL_TOKEN_MQTT=
CF_TUNNEL_TOKEN_MINIO_API=
CF_TUNNEL_TOKEN_MINIO_CONSOLE=
